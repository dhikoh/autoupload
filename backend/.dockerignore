# AutoPost Hub Backend — Docker ignore
# Prevents sensitive/unnecessary files from being copied into the Docker image

# Environment files (NEVER include in image)
.env
.env.*
!.env.example

# Database files (use persistent volumes instead)
*.db
*.sqlite
*.sqlite3

# Uploads (use persistent volumes instead)
uploads/
data/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
.eggs/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Logs
*.log
