# AutoPost Hub — Environment Variables
# Copy this file to .env and fill in the values before deploying

# ─── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-secret-key-minimum-64-characters-long-random-string

# ─── Superadmin Credentials (REQUIRED to create admin on first run) ────
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=YourStrongPasswordHere@2024
SUPERADMIN_NAME=Super Admin

# ─── Database ─────────────────────────────────────────────────
# Development:
DATABASE_URL=sqlite:///./autopost.db
# Production (PostgreSQL recommended):
# DATABASE_URL=postgresql://user:password@host:5432/autopost_db

# ─── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# ─── Redis / Celery (Optional — only needed if USE_CELERY=true) ─
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# ─── CORS (set to your frontend domain in production) ─────────
FRONTEND_URL=https://your-frontend-domain.com

# ─── Token Expiry ─────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_DAYS=7
