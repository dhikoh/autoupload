# AutoPost Hub — Environment Variables
# Copy this file to .env and fill in the values before deploying

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-minimum-64-characters-long-random-string

# ── Superadmin (REQUIRED — credentials for first admin account) ────────────────
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=YourStrongPasswordHere@2024
SUPERADMIN_NAME=Super Admin

# ── Database ───────────────────────────────────────────────────────────────────
#
# OPTION A: SQLite (development & small production)
# - Simple, no extra service needed
# - Max recommended: ~100 concurrent users
# - Use absolute path for Docker:
DATABASE_URL=sqlite:////app/data/autopost.db
#
# OPTION B: PostgreSQL (recommended for production)
# - Uncomment the line below and comment out OPTION A
# - Also uncomment the 'postgres' service in docker-compose.yml
# DATABASE_URL=postgresql://autopost:your-db-password@postgres:5432/autopost_db
# POSTGRES_PASSWORD=your-db-password

# ── File Storage ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500

# ── CORS (set to your frontend domain in production) ───────────────────────────
FRONTEND_URL=https://up.modula.click
NEXT_PUBLIC_API_URL=https://api.up.modula.click

# ── Auth ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_DAYS=7

# ── Redis / Celery (opsional — default: sync mode tanpa Celery) ────────────────
REDIS_URL=redis://redis:6379/0
USE_CELERY=false
